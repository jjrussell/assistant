# Memory data (stored locally or Google Drive, not Git) Google
areas/
projects/
archive/
inbox/
outbox/

# Claude Code local settings (contains permissions history and secrets)
.claude/settings.local.json

# Claude Code managed rules (symlink to local org config, machine-specific)
.claude/rules/managed

# Environment secrets
.env

# Obsidian (local editor config)
.obsidian/

# macOS
.DS_Store

# Environment-specific extensions. Create your own CLAUDE-[ENVIRONMENT].md
# files (e.g., CLAUDE-MYCOMPANY.md) for org-specific tools, integrations, and
# workflows. These are gitignored to keep org details private. Only
# CLAUDE-WORK.md is shared — it contains generic management patterns.
.claude/CLAUDE-*.md
!.claude/CLAUDE-WORK.md
.claude/SETUP.md

